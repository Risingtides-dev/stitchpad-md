#!/usr/bin/env bash
# stitchpad-ping — a tiny native popup to post a message to the pad and tag any
# combo of agents (which wakes them via the watcher). No deps: macOS osascript.
#
#   stitchpad-ping              # resolve pad from cwd, pop the dialog
#   STITCHPAD_FROM=john ...     # sender name (default: "john")
#
# Pick agents → type message → it posts "@a @b <message>" as you. The watcher's
# engagement gate wakes each tagged agent exactly once.
set -uo pipefail
_src="${BASH_SOURCE[0]}"; while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"; _src="$(readlink "$_src")"
  [ "${_src#/}" = "$_src" ] && _src="$_dir/$_src"
done
BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
SP="$BIN_DIR/stitchpad"
from="${STITCHPAD_FROM:-john}"

# Roster names (skip the sender so you don't tag yourself).
names="$("$SP" roster 2>/dev/null | awk -F'|' -v me="$from" '{gsub(/^ +| +$/,"",$1); if($1!=""&&$1!=me) print $1}')"
[ -z "$names" ] && { osascript -e 'display alert "stitchpad" message "No agents in the roster here. Run stitchpad init/join first, or launch from the pad directory."'; exit 1; }

# AppleScript list literal: "a","b","c"
list="$(printf '%s\n' "$names" | sed 's/.*/"&"/' | paste -sd, -)"

# 1) pick agents (multi-select)
picked="$(osascript <<OSA 2>/dev/null
set chosen to choose from list {$list} with title "stitchpad — tag agents" with prompt "Who should act on this? (⌘-click for multiple)" with multiple selections allowed
if chosen is false then return "__CANCEL__"
set out to ""
repeat with c in chosen
  set out to out & "@" & (c as string) & " "
end repeat
return out
OSA
)"
[ "$picked" = "__CANCEL__" ] || [ -z "$picked" ] && exit 0

# 2) type the message
msg="$(osascript <<OSA 2>/dev/null
set r to display dialog "Message to: $picked" default answer "" with title "stitchpad" buttons {"Cancel","Send"} default button "Send"
if button returned of r is "Cancel" then return "__CANCEL__"
return text returned of r
OSA
)"
[ "$msg" = "__CANCEL__" ] || [ -z "$msg" ] && exit 0

# 3) post as you (the tags wake them)
STITCHPAD_NAME="$from" "$SP" say "${picked}${msg}" >/dev/null 2>&1 \
  && osascript -e "display notification \"${picked}${msg}\" with title \"stitchpad → sent\"" 2>/dev/null \
  || osascript -e 'display alert "stitchpad" message "Failed to post — is this a pad directory?"'
